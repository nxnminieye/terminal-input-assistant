{
  "name": "terminal-input-assistant",
  "displayName": "Terminal Input Assistant | 终端输入助手",
  "description": "%extension.description%",
  "version": "0.2.1",
  "publisher": "TerminalInputAssistant",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "panel": [
        {
          "type": "webview",
          "id": "imeInput.panel",
          "name": "%views.panel.name%",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "imeInput.focus",
        "title": "%command.focus%"
      }
    ],
    "keybindings": [
      {
        "command": "imeInput.focus",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "imeInput.clearAfterSend": {
          "type": "boolean",
          "default": true,
          "description": "%config.clearAfterSend%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}